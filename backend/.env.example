# LogLens Configuration

# Get your API key from https://aistudio.google.com/
AI_API_KEY=your-gemini-api-key-here

# Create a Classic PAT with 'repo' scope at https://github.com/settings/tokens
GITHUB_TOKEN=your-github-pat-here

# Repository in owner/repo format
GITHUB_REPO=owner/repo

# Model choice (default: gemini-2.0-flash). Use any gemini-* or claude-* id.
AI_MODEL=gemini-2.0-flash

# (Optional) Target service base URL. When set, LogLens pings <URL>/health to
# decide the "Service status" pill. If unset, status falls back to a log-activity
# heuristic (down only when no logs flowed in the last 5 min).
TARGET_SERVICE_URL=http://localhost:8002
